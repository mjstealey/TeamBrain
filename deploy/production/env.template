# deploy/production/env.template — must-set values for the production
# TeamBrain deployment on pr.fabric-testbed.net.
#
# Workflow (see README.md for the full procedure):
#   1. On the VM, `cd /opt/supabase-stack && cp .env.example .env`
#      (.env.example comes from upstream supabase docker subtree).
#   2. Run `bash utils/generate-keys.sh` to mint a fresh set of
#      JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY / SUPABASE_PUBLISHABLE_KEY
#      / SUPABASE_SECRET_KEY / DASHBOARD_PASSWORD / etc.
#   3. **Edit `.env` to set the keys documented below.** Everything
#      else upstream pre-populated stays as-is.
#   4. Append the TEAMBRAIN_GITHUB_* block at the bottom (it's not in
#      upstream's example).
#
# This file is NOT copied to the VM verbatim. It's a checklist of
# what to set in /opt/supabase-stack/.env. Treat each block below
# as "open .env, find this key, set this value."
#
# Never commit a populated `.env` to git. The .gitignore already
# excludes it at the supabase-stack directory level.

# ---------------------------------------------------------------------------
# Public URL & TLS (set in .env)
# ---------------------------------------------------------------------------

# The public hostname Caddy serves on. Must resolve in DNS to the VM's
# public IPv4 before `docker compose up -d` (Let's Encrypt's HTTP-01
# challenge fails without DNS).
PROXY_DOMAIN=pr.fabric-testbed.net

# Set every site-facing URL to the public hostname so OAuth callbacks,
# email links, and SDK clients all resolve correctly.
SUPABASE_PUBLIC_URL=https://pr.fabric-testbed.net
API_EXTERNAL_URL=https://pr.fabric-testbed.net
SITE_URL=https://pr.fabric-testbed.net

# Caddy uses this as the ACME registration email for Let's Encrypt.
# Use a monitored alias (alerts on expiry-warning failures).
CERTBOT_EMAIL=ops-or-admin@example.org

# ---------------------------------------------------------------------------
# Studio admin (set in .env)
# ---------------------------------------------------------------------------

# Username for the Caddy basic-auth gate in front of Studio.
# DASHBOARD_PASSWORD is generated by `utils/generate-keys.sh`; keep
# that value, don't replace it. The Caddyfile hashes it with bcrypt
# at container boot.
DASHBOARD_USERNAME=supabase

# ---------------------------------------------------------------------------
# GitHub OAuth (Phase 1 — user login) (set in .env)
# ---------------------------------------------------------------------------

# Register a **production-specific** OAuth App at:
#   https://github.com/organizations/fabric-testbed/settings/applications
#
# App name:         TeamBrain (production)
# Homepage URL:     https://pr.fabric-testbed.net
# Callback URL:     https://pr.fabric-testbed.net/auth/v1/callback
#
# Do NOT reuse the scratch OAuth App — the callback URL differs and
# mixing environments under one Client Secret defeats key-rotation
# isolation.
GITHUB_ENABLED=true
GITHUB_CLIENT_ID=<from the production OAuth App>
GITHUB_SECRET=<from the production OAuth App>

# ---------------------------------------------------------------------------
# Embedding provider (set in .env — ADR 0001 § Decision 5)
# ---------------------------------------------------------------------------

# Active when the docker-compose.override.yml is on the "openai"
# embedding variant (the default). Use a production-billed OpenAI org
# key, not a personal one. Cost is ~$0.02 per 1M tokens for
# text-embedding-3-small — effectively free at pilot scale.
OPENAI_API_KEY=sk-...

# If the deployment uses the ollama variant instead, OMIT OPENAI_API_KEY
# and follow the ollama instructions in
# edge-functions/teambrain-mcp/docker-compose.override.yml.example.

# Optional. If unset, MCP tools require `project_slug` on every call.
TEAMBRAIN_DEFAULT_PROJECT_SLUG=fabric-testbed/fabric-core-api

# ---------------------------------------------------------------------------
# TeamBrain — Phase 3 GitHub-membership-sync App credentials
# (APPEND THIS BLOCK to .env — it's not present in upstream's example)
# ---------------------------------------------------------------------------

# Production GitHub App: `TeamBrain Sync — fabric-testbed` (distinct
# from the dev/scratch app named `TeamBrain Sync (dev) — fabric-testbed`
# per docs/deployment.md § "Scratch vs production: register two Apps").
#
# Setup procedure (one-time):
#   1. Register at:
#      https://github.com/organizations/fabric-testbed/settings/apps → New GitHub App
#      Permissions: Repository → Metadata: Read; Organization → Members: Read.
#      Webhook: disabled.
#   2. Install on the fabric-testbed org, scope to the production-pilot repo(s).
#   3. Generate a private key (.pem download).
#   4. CONVERT to PKCS#8 (GitHub ships PKCS#1 by default):
#        openssl pkcs8 -topk8 -in <download>.pem -out teambrain-sync.pkcs8.pem -nocrypt
#   5. Encode to single-line `\n` form for the env file:
#        awk 'BEGIN{ORS="\\n"} {print}' teambrain-sync.pkcs8.pem
#   6. Paste below, wrapped in double quotes.

TEAMBRAIN_GITHUB_APP_ID=
TEAMBRAIN_GITHUB_INSTALLATION_ID=
TEAMBRAIN_GITHUB_APP_PRIVATE_KEY=""
