# deploy/production/nginx/templates/pr.fabric-testbed.net.conf.template
#
# Public TLS terminator for the pr.fabric-testbed.net deployment
# (Path B — institutional FABRIC SAN cert, no Let's Encrypt).
#
# **This is an envsubst template, not a raw nginx conf.** The
# nginx:1.28-alpine image's /docker-entrypoint.d/20-envsubst-on-templates.sh
# script processes files matching *.template in /etc/nginx/templates/
# at container startup, runs envsubst over them, and writes the
# resulting files into /etc/nginx/conf.d/. We restrict which variables
# get substituted via NGINX_ENVSUBST_FILTER=^ANON_KEY$ in the compose
# overlay — without that, envsubst would clobber every $remote_addr /
# $host / $proxy_add_x_forwarded_for nginx variable too.
#
# Cert + key are mounted from /root/cert on the host at /etc/nginx/cert/
# inside the container.
#
# Edit workflow: change this file in the repo → git pull on the box →
# `docker compose up -d --force-recreate nginx`. Plain
# `nginx -s reload` is NOT enough because reload doesn't re-run the
# envsubst step. (For non-templated edits — e.g. tweaking
# nginx/html/index.html — reload IS sufficient; html is bind-mounted
# directly with no preprocessing.)

# Suppress the nginx version in the Server response header and on error
# pages. server_tokens defaults to "on", which emits the full build —
# e.g. "Server: nginx/1.28.3" — letting version-banner scanners
# fingerprint the exact release (this is how CVE-2026-1642 was flagged).
# Hiding it is obscurity, not a fix, but it's a cheap defense-in-depth
# layer. Declared here at http context (this file is included inside the
# stock image's http {} block) so it covers both the :80 redirect server
# and the :443 server below.
server_tokens off;

server {
    listen 80;
    listen [::]:80;
    server_name pr.fabric-testbed.net;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name pr.fabric-testbed.net;

    ssl_certificate     /etc/nginx/cert/fabric-other-services_fabric-testbed_net.pem;
    ssl_certificate_key /etc/nginx/cert/fabric-other-services.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Edge functions can return sizable payloads; bump the default 1m.
    client_max_body_size 50m;

    # Body-substitution: replace the literal placeholder __TEAMBRAIN_ANON_KEY__
    # in served HTML responses with the actual ANON_KEY from .env (injected
    # via envsubst at container startup). Used by the landing page to render
    # a copy-pasteable `claude mcp add ...` command pre-filled with the
    # apikey header. sub_filter_once off → replace every occurrence per
    # response; default sub_filter_types is text/html which is all we need.
    sub_filter '__TEAMBRAIN_ANON_KEY__' '${ANON_KEY}';
    sub_filter_once off;

    # Public Supabase API paths. Kong (reachable via the compose network
    # at http://kong:8000) routes each subpath to the right backend
    # internally — GoTrue, PostgREST, Realtime, Storage, Edge Functions.
    location ~ ^/(auth|rest|functions|storage|realtime)/ {
        proxy_pass         http://kong:8000;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_read_timeout 120s;
    }

    # Static landing page (deploy/production/nginx/html/index.html).
    # Pre-auth: explainer + Sign in with GitHub. Post-auth (URL fragment
    # parsed inline): identity panel + JWT for terminal/MCP-client setup.
    #
    # Studio is NOT exposed here. Admins SSH-tunnel to Kong's loopback
    # and reach Studio that way (see ADR 0001 § "Studio admin"):
    #   ssh -L 3000:127.0.0.1:8000 nrig-service@pr.fabric-testbed.net
    #   open http://localhost:3000   # Kong forwards / → Studio
    location = / {
        root  /usr/share/nginx/html;
        try_files /index.html =404;
    }

    # OpenAPI 3.1 spec for the REST surface
    # (deploy/production/nginx/html/openapi.yaml). Served as a public,
    # unauthenticated contract — it documents the API but contains no
    # secrets. default_type is set explicitly because nginx's bundled
    # mime.types has no mapping for .yaml. sub_filter only touches
    # text/html, so the spec is served verbatim.
    location = /openapi.yaml {
        root         /usr/share/nginx/html;
        default_type application/yaml;
        try_files    /openapi.yaml =404;
    }

    # Anything else under / that we don't explicitly route is a 404.
    # (The named API paths above are still matched first by their
    # location regex; this block only fires for non-API, non-root paths.)
    location / {
        return 404;
    }
}
