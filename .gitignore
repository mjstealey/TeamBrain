# Local env / secrets
.env
.env.*
!.env.template
!.env.example

# Supabase local dev
.supabase/
supabase/.temp/
supabase/.branches/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Node / TypeScript
node_modules/
.deno/
*.tsbuildinfo

# Deno edge functions don't pin a lockfile — `deno check` regenerates it
edge-functions/*/deno.lock

# IDE / OS
.DS_Store
.idea/
.vscode/
!.vscode/settings.json.example

# Local Claude Code state (machine-specific — settings, scheduled-task locks, etc.)
# but DO track shared, repo-committed slash commands under .claude/commands/.
.claude/*
!.claude/commands/

# Local Codex state
.codex/

# Logs
*.log
logs/

# Generated artifacts (presentations, renders, scratch builds) — not part of the repo
outputs/
